# ─── Production ───────────────────────────────────────────────────────────────
# Full URL of the Frappe/ERPNext server once deployed (no trailing slash).
# Leave empty to rely on the same-origin reverse proxy (e.g. Nginx on the server).
VITE_API_BASE_URL=

# ─── Dev proxy target (vite.config.js only — never exposed to the browser) ───
# Used by the Vite dev server to forward /api/* requests.
# Override in .env.local with your current IP or domain without committing it.
API_TARGET=http://127.0.0.1:8013

